{
  "name": "cargochain-prototype-factory",
  "version": "0.1.0",
  "private": true,
  "description": "CargoChain prototype — factory-of-clones variant. One contract per package via EIP-1167 minimal proxies. Parallel to ../prototype/ which uses a single mapping-based registry.",
  "scripts": {
    "node": "hardhat node",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "lint:sol": "solhint contracts/**/*.sol",
    "lint": "npm run lint:sol"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "ethers": "^6.11.0",
    "hardhat": "^2.22.0",
    "solhint": "^5.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.0"
  }
}
