{
  "name": "cargochain-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "CargoChain prototype — factory-of-clones design. Each package is its own EIP-1167 minimal-proxy contract spawned by PackageFactory.",
  "scripts": {
    "node": "hardhat node",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "oracle:sim": "tsx scripts/oracle-simulator.ts",
    "app:dev": "cd app && next dev",
    "app:build": "cd app && next build",
    "lint:sol": "solhint contracts/**/*.sol",
    "lint": "npm run lint:sol"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "ethers": "^6.11.0",
    "hardhat": "^2.28.6",
    "solhint": "^5.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.4.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.0"
  }
}
